3903:9:websocket;0:~8:response;648:6:reason;2:OK,11:status_code;3:200#13:timestamp_end;16:1784454189.10772^15:timestamp_start;18:1784454189.1063714^8:trailers;0:~7:content;337:{"model":"qwen3:4b-instruct","created_at":"2026-07-19T09:43:09.1034956Z","message":{"role":"assistant","content":"{\"title\": \"👋 Hello World\"}"},"done":true,"done_reason":"stop","total_duration":7015181600,"load_duration":4326780100,"prompt_eval_count":289,"prompt_eval_duration":2155561000,"eval_count":9,"eval_duration":522259000},7:headers;127:51:12:Content-Type,31:application/json; charset=utf-8,]40:4:Date,29:Sun, 19 Jul 2026 09:43:09 GMT,]24:14:Content-Length,3:337,]]12:http_version;8:HTTP/1.1,}7:request;2004:4:path;9:/api/chat,9:authority;0:,6:scheme;4:http,6:method;4:POST,4:port;5:11434#4:host;20:host.docker.internal;13:timestamp_end;18:1784454182.0856113^15:timestamp_start;18:1784454182.0839558^8:trailers;0:~7:content;1519:{"model": "qwen3:4b-instruct", "messages": [{"role": "user", "content": "### Task:\nGenerate a concise, 3-5 word title with an emoji summarizing the chat history.\n### Guidelines:\n- The title should clearly represent the main theme or subject of the conversation.\n- Use emojis that enhance understanding of the topic, but avoid quotation marks or special formatting.\n- Write the title in the chat's primary language; default to English if multilingual.\n- Prioritize accuracy over excessive creativity; keep it clear and simple.\n- Your entire response must consist solely of the JSON object, without any introductory or concluding text.\n- The output must be a single, raw JSON object, without any markdown code fences or other encapsulating text.\n- Ensure no conversational text, affirmations, or explanations precede or follow the raw JSON output, as this will cause direct parsing failure.\n### Output:\nJSON format: { \"title\": \"your concise title here\" }\n### Examples:\n- { \"title\": \"\ud83d\udcc9 Stock Market Trends\" },\n- { \"title\": \"\ud83c\udf6a Perfect Chocolate Chip Recipe\" },\n- { \"title\": \"Evolution of Music Streaming\" },\n- { \"title\": \"Remote Work Productivity Tips\" },\n- { \"title\": \"Artificial Intelligence in Healthcare\" },\n- { \"title\": \"\ud83c\udfae Video Game Development Insights\" }\n### Chat History:\n<chat_history>\nUSER: \u041f\u0440\u0438\u0432\u0435\u0442\nASSISTANT: \n</chat_history>"}], "stream": false, "num_predict": 1000, "options": {"num_ctx": 20000}},7:headers;221:37:4:Host,26:host.docker.internal:11434,]36:12:Content-Type,16:application/json,]15:6:Accept,3:*/*,]40:15:Accept-Encoding,17:gzip, deflate, br,]44:10:User-Agent,26:Python/3.11 aiohttp/3.13.5,]25:14:Content-Length,4:1519,]]12:http_version;8:HTTP/1.1,}6:backup;0:~17:timestamp_created;18:1784454182.0842812^7:comment;0:;8:metadata;0:}6:marked;0:;9:is_replay;0:~11:intercepted;5:false!11:server_conn;489:3:via;0:~19:timestamp_tcp_setup;17:1784454182.082258^7:address;32:20:host.docker.internal;5:11434#]19:timestamp_tls_setup;0:~13:timestamp_end;18:1784454215.5209117^15:timestamp_start;18:1784454182.0719907^3:sni;0:~11:tls_version;0:~11:cipher_list;0:]6:cipher;0:~11:alpn_offers;0:]4:alpn;0:~16:certificate_list;0:]3:tls;5:false!5:error;0:~18:transport_protocol;3:tcp;2:id;36:ba08aa95-a888-4759-93ec-82dc757fd4fb;8:sockname;22:10:172.17.0.3;5:58928#]8:peername;26:14:192.168.65.254;5:11434#]}11:client_conn;458:10:proxy_mode;41:reverse:http://host.docker.internal:11434;8:mitmcert;0:~19:timestamp_tls_setup;0:~13:timestamp_end;18:1784454215.5194788^15:timestamp_start;18:1784454182.0688248^3:sni;0:~11:tls_version;0:~11:cipher_list;0:]6:cipher;0:~11:alpn_offers;0:]4:alpn;0:~16:certificate_list;0:]3:tls;5:false!5:error;0:~18:transport_protocol;3:tcp;2:id;36:615c69bd-f722-477c-9fb1-b443b0b92927;8:sockname;21:10:172.17.0.3;4:8080#]8:peername;22:10:172.17.0.1;5:58716#]}5:error;0:~2:id;36:433b2883-02eb-40ee-ac7a-6fed5cb372b0;4:type;4:http;7:version;2:21#}26476:9:websocket;0:~8:response;2520:6:reason;2:OK,11:status_code;3:200#13:timestamp_end;17:17